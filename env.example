# Server
NODE_ENV=development
PORT=3000

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_app
# Optional: Neon direct URL for migrations (auto-derived from pooler URL when omitted)
# DIRECT_DATABASE_URL=

# JWT — use secrets longos e aleatórios (mín. 32 caracteres)
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origem permitida do frontend
# Em production, apenas esta URL poderá acessar a API via browser
FRONTEND_URL=http://localhost:5173

# Redis (cache opcional — fallback in-memory se ausente ou indisponível)
# Local: redis://localhost:6379
# Render/production: URL do serviço Redis gerenciado
REDIS_URL=redis://localhost:6379
