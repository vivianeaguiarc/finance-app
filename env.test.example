# Test environment — copy to .env.test and adjust if needed
NODE_ENV=test

# Isolated PostgreSQL database (docker compose postgres-test uses port 5434)
DATABASE_URL=postgresql://postgres:password@localhost:5434/finance_app_test

JWT_ACCESS_SECRET=test_access_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=test_refresh_secret_at_least_32_characters_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
