# Server
NODE_ENV=development
PORT=3000

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_app
# Optional: Neon direct (non-pooler) URL for migrations. If omitted, pooler URLs are auto-converted.
# DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_at_least_32_chars

# CORS (required in production)
FRONTEND_URL=http://localhost:5173
