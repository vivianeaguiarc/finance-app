datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String                @id @default(uuid())
  first_name           String                @db.VarChar(50)
  last_name            String                @db.VarChar(50)
  email                String                @unique @db.VarChar(100)
  password             String                @db.VarChar(100)
  transactions         Transaction[]
  refreshTokenSessions RefreshTokenSession[]

  @@map("users")
}

// Modelando a Tabela de Transações no Prisma

model Transaction {
  id         String          @id @default(uuid())
  user_id    String
  user       User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name       String          @db.VarChar(50)
  date       DateTime        @db.Date
  amount     Decimal         @db.Decimal(10, 2)
  type       TransactionType
  created_at DateTime        @default(now()) @map("created_at")

  @@index([user_id])
  @@index([user_id, date])
  @@map("transactions")
}

enum TransactionType {
  EARNING
  EXPENSE
  INVESTMENT
}

model RefreshTokenSession {
  id                   String    @id @default(uuid())
  user_id              String    @map("user_id")
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash           String    @map("token_hash")
  expires_at           DateTime  @map("expires_at")
  revoked_at           DateTime? @map("revoked_at")
  replaced_by_token_id String?   @map("replaced_by_token_id")
  created_at           DateTime  @default(now()) @map("created_at")
  updated_at           DateTime  @updatedAt @map("updated_at")

  @@index([user_id])
  @@index([expires_at])
  @@map("refresh_token_sessions")
}

