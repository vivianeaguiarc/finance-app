# Docker Compose — copy to .env.docker before running: cp .env.docker.example .env.docker

NODE_ENV=development
PORT=3000

# Service hostnames match docker-compose service names (internal network)
DATABASE_URL=postgresql://postgres:password@postgres:5432/finance_app
REDIS_URL=redis://redis:6379

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres

JWT_ACCESS_SECRET=docker_dev_access_secret_change_me_min_32_chars
JWT_REFRESH_SECRET=docker_dev_refresh_secret_change_me_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
